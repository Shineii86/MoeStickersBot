  {
   "cell_type": "code",
   "metadata": {
    "cellView": "form",
    "id": "moestickersbot"
   },
   "source": [
    "#@title 🚀 MoeStickersBot — One-Click Deploy\n",
    "#@markdown ---\n",
    "#@markdown **✨ Full ANSI colors • Animated spinners • Live bot logs**\n",
    "#@markdown\n",
    "#@markdown Just run this cell. Everything is pre-configured.\n",
    "#@markdown ---\n",
    "\n",
    "import subprocess, sys, os, time, threading, signal, re\n",
    "from IPython.display import display, HTML, clear_output\n",
    "\n",
    "# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n",
    "# 🎨 ANSI Color Engine\n",
    "# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n",
    "class C:\n",
    "    RESET   = '\\033[0m'\n",
    "    BOLD    = '\\033[1m'\n",
    "    DIM     = '\\033[2m'\n",
    "    ITALIC  = '\\033[3m'\n",
    "    UNDER   = '\\033[4m'\n",
    "    # Foreground\n",
    "    RED     = '\\033[91m'\n",
    "    GREEN   = '\\033[92m'\n",
    "    YELLOW  = '\\033[93m'\n",
    "    BLUE    = '\\033[94m'\n",
    "    MAGENTA = '\\033[95m'\n",
    "    CYAN    = '\\033[96m'\n",
    "    WHITE   = '\\033[97m'\n",
    "    GRAY    = '\\033[90m'\n",
    "    # Background\n",
    "    BG_RED     = '\\033[41m'\n",
    "    BG_GREEN   = '\\033[42m'\n",
    "    BG_YELLOW  = '\\033[43m'\n",
    "    BG_BLUE    = '\\033[44m'\n",
    "    BG_MAGENTA = '\\033[45m'\n",
    "    BG_CYAN    = '\\033[46m'\n",
    "    BG_WHITE   = '\\033[47m'\n",
    "    BG_GRAY    = '\\033[100m'\n",
    "\n",
    "# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n",
    "# ⠋ Spinner Engine\n",
    "# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n",
    "class Spinner:\n",
    "    FRAMES = ['⠋', '⠙', '⠹', '⠸', '⠼', '⠴', '⠦', '⠧', '⠇', '⠏']\n",
    "    def __init__(self, msg=\"Working...\"):\n",
    "        self.msg = msg\n",
    "        self.running = False\n",
    "        self.thread = None\n",
    "    def _animate(self):\n",
    "        i = 0\n",
    "        while self.running:\n",
    "            frame = self.FRAMES[i % len(self.FRAMES)]\n",
    "            sys.stdout.write(f'\\r  {C.CYAN}{C.BOLD}{frame}{C.RESET} {C.DIM}{self.msg}{C.RESET}   ')\n",
    "            sys.stdout.flush()\n",
    "            time.sleep(0.08)\n",
    "            i += 1\n",
    "    def start(self, msg=None):\n",
    "        if msg: self.msg = msg\n",
    "        self.running = True\n",
    "        self.thread = threading.Thread(target=self._animate, daemon=True)\n",
    "        self.thread.start()\n",
    "    def stop(self, success=True, msg=None):\n",
    "        self.running = False\n",
    "        if self.thread: self.thread.join(timeout=1)\n",
    "        icon = f'{C.GREEN}✔{C.RESET}' if success else f'{C.RED}✘{C.RESET}'\n",
    "        text = msg or self.msg\n",
    "        sys.stdout.write(f'\\r  {icon} {text}\\n')\n",
    "        sys.stdout.flush()\n",
    "\n",
    "# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n",
    "# 🏷️ Badge Helpers\n",
    "# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n",
    "def badge_ok(msg):\n",
    "    print(f'  {C.BG_GREEN}{C.WHITE}{C.BOLD} SUCCESS {C.RESET} {C.GREEN}{msg}{C.RESET}')\n",
    "def badge_err(msg):\n",
    "    print(f'  {C.BG_RED}{C.WHITE}{C.BOLD}  ERROR  {C.RESET} {C.RED}{msg}{C.RESET}')\n",
    "def badge_warn(msg):\n",
    "    print(f'  {C.BG_YELLOW}{C.WHITE}{C.BOLD}  WARN   {C.RESET} {C.YELLOW}{msg}{C.RESET}')\n",
    "def badge_info(msg):\n",
    "    print(f'  {C.BG_BLUE}{C.WHITE}{C.BOLD}  INFO   {C.RESET} {C.CYAN}{msg}{C.RESET}')\n",
    "def banner(text):\n",
    "    w = 56\n",
    "    print(f'\\n{C.MAGENTA}{C.BOLD}{'━' * w}')\n",
    "    print(f'  🌸 {text}')\n",
    "    print(f\"{'━' * w}{C.RESET}\\n\")\n",
    "\n",
    "# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n",
    "# 🔧 Configuration (Pre-set — no input needed)\n",
    "# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n",
    "BOT_TOKEN = \"8760934506:AAF2U0ZInHED8r7V_Exz-z8SeIqxLszCKMU\"  #@param {type:\"string\"}\n",
    "REPO_URL  = \"https://github.com/Shineii86/MoeStickersBot.git\"  #@param {type:\"string\"}\n",
    "LOG_LEVEL = \"info\"  #@param [\"debug\", \"info\", \"warn\", \"error\"]\n",
    "\n",
    "WORK_DIR = \"/content/MoeStickersBot\"\n",
    "BOT_BIN  = os.path.join(WORK_DIR, \"MoeStickersBot\")\n",
    "\n",
    "# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n",
    "# 🚀 Main Deployment\n",
    "# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n",
    "banner(\"MoeStickersBot — One-Click Deploy\")\n",
    "\n",
    "# Step 1: Install system dependencies\n",
    "sp = Spinner(\"Installing system dependencies...\")\n",
    "sp.start()\n",
    "result = subprocess.run(\n",
    "    \"apt-get update -qq && apt-get install -y -qq golang-go imagemagick libarchive-tools gifsicle exiv2 ffmpeg 2>&1 | tail -1\",\n",
    "    shell=True, capture_output=True, text=True\n",
    ")\n",
    "sp.stop(result.returncode == 0, \"System dependencies installed\")\n",
    "\n",
    "# Step 2: Clone repository\n",
    "sp = Spinner(\"Cloning MoeStickersBot repository...\")\n",
    "sp.start()\n",
    "if os.path.exists(WORK_DIR):\n",
    "    result = subprocess.run(f\"cd {WORK_DIR} && git pull --quiet\", shell=True, capture_output=True, text=True)\n",
    "else:\n",
    "    result = subprocess.run(f\"git clone --quiet {REPO_URL} {WORK_DIR}\", shell=True, capture_output=True, text=True)\n",
    "sp.stop(result.returncode == 0, \"Repository cloned\")\n",
    "\n",
    "# Step 3: Build the bot\n",
    "sp = Spinner(\"Building MoeStickersBot (Go compile)...\")\n",
    "sp.start()\n",
    "env = os.environ.copy()\n",
    "env[\"PATH\"] = \"/usr/local/go/bin:/usr/lib/go/bin:\" + env.get(\"PATH\", \"\")\n",
    "result = subprocess.run(\n",
    "    \"go build -o MoeStickersBot ./cmd/MoeStickersBot/\",\n",
    "    shell=True, capture_output=True, text=True, cwd=WORK_DIR, env=env\n",
    ")\n",
    "sp.stop(result.returncode == 0, \"Build complete\" if result.returncode == 0 else f\"Build failed: {result.stderr[:200]}\")\n",
    "\n",
    "if result.returncode != 0:\n",
    "    badge_err(\"Build failed! Check errors above.\")\n",
    "    sys.exit(1)\n",
    "\n",
    "# Step 4: Verify dependencies\n",
    "sp = Spinner(\"Verifying dependencies...\")\n",
    "sp.start()\n",
    "deps_ok = True\n",
    "for dep in [\"ffmpeg\", \"convert\", \"bsdtar\", \"gifsicle\", \"exiv2\"]:\n",
    "    check = subprocess.run(f\"which {dep}\", shell=True, capture_output=True)\n",
    "    if check.returncode != 0:\n",
    "        badge_warn(f\"Missing dependency: {dep}\")\n",
    "        deps_ok = False\n",
    "sp.stop(deps_ok, \"All dependencies verified\" if deps_ok else \"Some dependencies missing (non-fatal)\")\n",
    "\n",
    "badge_ok(f\"Bot binary: {BOT_BIN}\")\n",
    "badge_info(f\"Log level: {LOG_LEVEL}\")\n",
    "print()\n",
    "\n",
    "# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n",
    "# 📡 Live Bot Logs (streaming with ANSI colors)\n",
    "# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n",
    "banner(\"Live Bot Logs — Press ■ (Stop) to terminate\")\n",
    "print(f\"  {C.DIM}Bot is running. Logs appear below in real-time.{C.RESET}\")\n",
    "print(f\"  {C.DIM}Send /start to your bot on Telegram to test.{C.RESET}\n")\n",
    "\n",
    "# Colorize log lines\n",
    "def colorize_log(line):\n",
    "    # Logrus color codes are already embedded, but we enhance plain text too\n",
    "    line = line.replace('INFO', f'{C.BG_CYAN}{C.WHITE} INFO {C.RESET}')\n",
    "    line = line.replace('WARNING', f'{C.BG_YELLOW}{C.WHITE} WARN {C.RESET}')\n",
    "    line = line.replace('ERROR', f'{C.BG_RED}{C.WHITE} ERROR {C.RESET}')\n",
    "    line = line.replace('DEBUG', f'{C.BG_GRAY}{C.WHITE} DEBUG {C.RESET}')\n",
    "    line = line.replace('FATAL', f'{C.BG_RED}{C.WHITE}{C.BOLD} FATAL {C.RESET}')\n",
    "    # Colorize common messages\n",
    "    line = line.replace('Bot OK', f'{C.GREEN}{C.BOLD}Bot OK{C.RESET}')\n",
    "    line = line.replace('one sticker commited', f'{C.GREEN}✔ sticker committed{C.RESET}')\n",
    "    line = line.replace('Failed to add one sticker', f'{C.RED}{C.BOLD}✘ sticker failed{C.RESET}')\n",
    "    line = line.replace('Success', f'{C.GREEN}{C.BOLD}Success{C.RESET}')\n",
    "    line = line.replace('Fatal error', f'{C.RED}{C.BOLD}Fatal error{C.RESET}')\n",
    "    line = line.replace('Attempting to initialize', f'{C.CYAN}Attempting to initialize{C.RESET}')\n",
    "    line = line.replace('convertKakaoAnimated OK', f'{C.GREEN}convertKakaoAnimated OK{C.RESET}')\n",
    "    line = line.replace('convertKakaoAnimated', f'{C.YELLOW}convertKakaoAnimated{C.RESET}')\n",
    "    line = line.replace('STICKER_VIDEO_LONG', f'{C.YELLOW}{C.BOLD}STICKER_VIDEO_LONG{C.RESET}')\n",
    "    line = line.replace('safe mode', f'{C.MAGENTA}safe mode{C.RESET}')\n",
    "    return line\n",
    "\n",
    "# Launch bot with streaming output\n",
    "process = subprocess.Popen(\n",
    "    [BOT_BIN, \"--bot_token\", BOT_TOKEN, \"--log_level\", LOG_LEVEL],\n",
    "    stdout=subprocess.PIPE, stderr=subprocess.STDOUT,\n",
    "    cwd=WORK_DIR, bufsize=1, universal_newlines=True\n",
    ")\n",
    "\n",
    "try:\n",
    "    for line in process.stdout:\n",
    "        line = line.rstrip()\n",
    "        if line:\n",
    "            print(colorize_log(line))\n",
    "except KeyboardInterrupt:\n",
    "    badge_warn(\"Interrupted by user\")\n",
    "finally:\n",
    "    process.terminate()\n",
    "    try:\n",
    "        process.wait(timeout=5)\n",
    "    except subprocess.TimeoutExpired:\n",
    "        process.kill()\n",
    "    badge_info(\"Bot stopped.\")\n"
   ],
   "execution_count": null,
   "outputs": []
  }
 ]
}
